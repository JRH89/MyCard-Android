<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"
        android:text="Share My Card"
        android:textColor="@color/onSurface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/shareLink"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingVertical="14dp"
        android:text="Share Link"
        android:textColor="@color/secondary"
        android:textSize="18sp"
        app:backgroundTint="@color/background"
        app:icon="@android:drawable/ic_menu_share"
        app:iconTint="@color/secondary"
        app:iconPadding="8dp"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/shareQRCode"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingVertical="14dp"
        android:text="Share QR Code"
        android:textColor="@color/primary"
        android:textSize="18sp"
        app:backgroundTint="@color/background"
        app:icon="@drawable/qrcode"
        app:iconTint="@color/primary"
        app:iconPadding="8dp"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/shareEmail"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingVertical="14dp"
        android:text="Share via Email"
        android:textColor="@color/onSurface"
        android:textSize="18sp"
        app:backgroundTint="@color/background"
        app:icon="@android:drawable/ic_dialog_email"
        app:iconTint="@color/onSurface"
        app:iconPadding="8dp"
        app:cornerRadius="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelShare"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingVertical="12dp"
        android:text="Cancel"
        android:textColor="@color/error_muted"
        app:strokeColor="@color/error_muted"
        app:cornerRadius="12dp" />

</LinearLayout>