<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_menu"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/menuTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:text="@string/menu_caps"
                android:textColor="@color/onSurface"
                android:textSize="32sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/qr_image"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/buttonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/todoButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingVertical="14dp"
                    android:text="@string/todo_list"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    app:backgroundTint="@color/surface"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/checkbox_on_background"
                    app:iconPadding="8dp"
                    app:iconTint="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/supportButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingVertical="14dp"
                    android:text="@string/support"
                    android:textColor="@color/secondary"
                    android:textSize="20sp"
                    app:backgroundTint="@color/surface"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_help"
                    app:iconPadding="8dp"
                    app:iconTint="@color/secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/editCard"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingVertical="14dp"
                    android:text="@string/edit_card"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    app:backgroundTint="@color/surface"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconPadding="8dp"
                    app:iconTint="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/deleteAcct"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingVertical="14dp"
                    android:text="@string/delete_account"
                    android:textColor="@color/error"
                    android:textSize="20sp"
                    app:backgroundTint="@color/surface"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconPadding="8dp"
                    app:iconTint="@color/error" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/logout"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:paddingVertical="14dp"
                    android:text="@string/logout"
                    android:textColor="@color/onSurface"
                    android:textSize="20sp"
                    app:backgroundTint="@color/surface"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconPadding="8dp"
                    app:iconTint="@color/onSurface" />

            </LinearLayout>

            <TextView
                android:id="@+id/websiteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:padding="8dp"
                android:text="@string/visit_my_card_for_the_web"
                android:textColor="@color/secondary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/buttonRow"
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>